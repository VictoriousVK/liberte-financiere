        .social-links a {
            color: var(--text-muted);
            font-size: 1.8rem;
        }
        .social-links a:hover {
            color: var(--blue-electric);
        }
        .disclaimer {
            font-size: 0.75rem;
            color: #6a7a8e;
            max-width: 900px;
            margin: 20px auto 0;
