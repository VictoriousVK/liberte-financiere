        }
        .fade-in.visible {
            opacity: 1;
            transform: translateY(0);
        }

        @media (max-width: 680px) {
            .hero h1 { font-size: 2.5rem; }
            .section-title { font-size: 2rem; }
            .hero-buttons { flex-direction: column; gap: 15px; }
            .btn { width: 100%; text-align: center; }
        }
    </style>
</head>
