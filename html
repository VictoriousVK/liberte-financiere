        /* ================= VARIABLES & RESET ================= */
        :root {
            --bg-black: #050505;
            --bg-card: rgba(15, 20, 30, 0.7);
            --blue-electric: #00e5ff;
            --blue-glow: rgba(0, 229, 255, 0.4);
            --gold-premium: #d4af37;
            --gold-glow: rgba(212, 175, 55, 0.4);
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --transition: all 0.3s ease-in-out;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Montserrat', sans-serif;
            background-color: var(--bg-black);
            color: var(--text-main);
            overflow-x: hidden;
            background-image: 
                radial-gradient(circle at 15% 50%, rgba(0, 229, 255, 0.05), transparent 25%),
                radial-gradient(circle at 85% 30%, rgba(212, 175, 55, 0.05), transparent 25%);
        }

        h1, h2, h3, h4 {
            font-family: 'Space Grotesk', sans-serif;
        }

        a { text-decoration: none; }
        
        /* ================= REUSABLE COMPONENTS ================= */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
        }

        .section-title {
            text-align: center;
            font-size: 2.5rem;
            margin-bottom: 10px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .section-subtitle {
            text-align: center;
            color: var(--gold-premium);
            margin-bottom: 50px;
            font-weight: 600;
        }

        .btn {
            display: inline-block;
            padding: 15px 30px;
            border-radius: 5px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            cursor: pointer;
            transition: var(--transition);
            border: none;
        }

        .btn-primary {
            background: linear-gradient(45deg, #007bb5, var(--blue-electric));
            color: #000;
            box-shadow: 0 0 15px var(--blue-glow);
        }

        .btn-primary:hover {
            box-shadow: 0 0 25px var(--blue-glow);
            transform: translateY(-2px);
        }

        .btn-gold {
            background: linear-gradient(45deg, #a67c00, var(--gold-premium));
            color: #000;
            box-shadow: 0 0 15px var(--gold-glow);
        }

        .btn-gold:hover {
            box-shadow: 0 0 25px var(--gold-glow);
            transform: translateY(-2px);
        }

        /* Glassmorphism Cards */
        .glass-card {
            background: var(--bg-card);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 15px;
            padding: 30px;
            transition: var(--transition);
        }

        .glass-card:hover {
            border-color: var(--blue-electric);
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 229, 255, 0.1);
        }

        /* ================= HEADER & URGENCY BAR ================= */
        .urgency-bar {
            background: var(--gold-premium);
            color: #000;
            text-align: center;
            padding: 10px;
            font-weight: 700;
            font-size: 0.9rem;
            animation: pulseBanner 2s infinite;
        }

        @keyframes pulseBanner {
            0% { background: var(--gold-premium); }
            50% { background: #ffdf00; }
            100% { background: var(--gold-premium); }
        }

        /* ================= HERO SECTION ================= */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            position: relative;
            padding-top: 50px;
        }

        /* Chart Background Overlay */
        .hero::before {
            content: '';
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: url('data:image/svg+xml;utf8,<svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg"><path d="M0,500 L100,450 L200,480 L300,300 L400,350 L500,200 L600,250 L700,100 L800,150 L900,50 L1000,80 L1200,0" stroke="rgba(0, 229, 255, 0.1)" stroke-width="2" fill="none"/></svg>') no-repeat center center;
            background-size: cover;
            z-index: -1;
            opacity: 0.5;
        }

        .hero-content {
            text-align: center;
            max-width: 900px;
            margin: 0 auto;
        }

        .hero h1 {
            font-size: 4rem;
            margin-bottom: 20px;
            background: linear-gradient(to right, #fff, var(--blue-electric));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .hero p {
            font-size: 1.2rem;
            color: var(--text-muted);
            margin-bottom: 40px;
            line-height: 1.6;
        }

        .hero-buttons {
            display: flex;
            gap: 20px;
            justify-content: center;
            flex-wrap: wrap;
        }

        /* ================= COACHES SECTION ================= */
        .coaches {
            padding: 100px 0;
            position: relative;
        }

        .coaches-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 40px;
            margin-top: 50px;
        }

        .coach-card {
            text-align: center;
            position: relative;
            overflow: hidden;
        }

        .coach-card::before {
            content: '';
            position: absolute;
            top: -2px; left: -2px; right: -2px; bottom: -2px;
            background: linear-gradient(45deg, transparent, var(--blue-electric), transparent);
            z-index: -1;
            border-radius: 16px;
            opacity: 0;
            transition: var(--transition);
        }

        .coach-card:hover::before { opacity: 1; }

        .coach-img {
            width: 150px;
            height: 150px;
            border-radius: 50%;
            margin: 0 auto 20px;
            border: 3px solid var(--gold-premium);
            object-fit: cover;
            background: #1a1a1a; /* Placeholder bg */
        }

        .coach-name {
            font-size: 1.8rem;
            color: var(--blue-electric);
            margin-bottom: 5px;
        }

        .coach-title {
            color: var(--gold-premium);
            font-weight: 600;
            margin-bottom: 15px;
            font-size: 0.9rem;
            text-transform: uppercase;
        }

        .coach-bio {
            color: var(--text-muted);
            font-size: 0.95rem;
            line-height: 1.5;
        }

        /* ================= OFFERS / MODULES SECTION ================= */
        .offers {
            padding: 100px 0;
            background: rgba(10, 10, 10, 0.8);
        }

        .accordion {
            max-width: 800px;
            margin: 0 auto 40px;
        }

        .accordion-item {
            background: var(--bg-card);
            margin-bottom: 15px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.05);
            overflow: hidden;
        }

        .accordion-header {
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            font-weight: 600;
            transition: var(--transition);
        }

        .accordion-header:hover {
            color: var(--blue-electric);
            background: rgba(0, 229, 255, 0.05);
        }

        .accordion-content {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.4s ease;
            background: rgba(0,0,0,0.3);
            padding: 0 20px;
        }

        .accordion-content p {
            padding: 20px 0;
            color: var(--text-muted);
            line-height: 1.6;
        }

        .accordion-item.active .accordion-content {
            max-height: 200px; /* Arbitrary high value for CSS transition */
        }

        .accordion-item.active .accordion-header {
            border-bottom: 1px solid rgba(255,255,255,0.05);
            color: var(--blue-electric);
        }

        .accordion-item.active i {
            transform: rotate(180deg);
        }

        .pricing-card {
            text-align: center;
            max-width: 400px;
            margin: 0 auto;
            border-color: var(--gold-premium);
        }

        .price {
